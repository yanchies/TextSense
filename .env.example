# TextSense v2 — example environment file
# Copy this to .env and fill in values if you prefer env-based config.
# Alternatively, enter your API key directly in the Settings panel in the UI.

# Not required — the UI settings panel stores keys in browser localStorage.
# These are here if you ever wire up server-side key injection.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
